{
  "name": "baltic-auction-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Baltic Auction Platform — auction engine + admin panel (LV/EE/LT). TypeScript monorepo: Fastify API, PostgreSQL + Redis, Vite/React admin.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter @auction/domain test",
    "test:integration": "pnpm --filter @auction/api test",
    "test:e2e": "pnpm --filter @auction/e2e e2e",
    "db:migrate": "pnpm --filter @auction/db migrate",
    "db:seed": "pnpm --filter @auction/db seed",
    "dev:api": "pnpm --filter @auction/api dev",
    "dev:admin": "pnpm --filter @auction/admin dev",
    "dev:web": "pnpm --filter @auction/web dev"
  }
}
