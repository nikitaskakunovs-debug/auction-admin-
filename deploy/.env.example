# Copy to deploy/.env and fill in. NEVER commit the real .env.

# ── Domains & TLS ────────────────────────────────────────────────────────────
# Your apex domain. Subdomains api.<domain> and admin.<domain> are derived.
DOMAIN=izsoli.lv
# Let's Encrypt notifications.
ACME_EMAIL=nikita.skakunovs@gmail.com
# Per-country storefront origins (only if you run the ccTLD trio; otherwise
# leave unset and everything self-references the single DOMAIN).
#ORIGIN_LV=https://izsoli.lv
#ORIGIN_EE=https://izsoli.ee
#ORIGIN_LT=https://izsoli.lt

# ── Secrets ──────────────────────────────────────────────────────────────────
# openssl rand -hex 24   (both of these)
POSTGRES_PASSWORD=
JWT_SECRET=

# ── First admin (used once by the seed; remove afterwards) ──────────────────
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
# 2FA is enforced: you enroll your authenticator on first login.

# ── Photos (DigitalOcean Spaces, FRA1) ───────────────────────────────────────
STORAGE_DRIVER=s3
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_REGION=fra1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# The bucket's public URL (enable CDN in Spaces and use the CDN endpoint):
S3_PUBLIC_URL=https://<bucket>.fra1.cdn.digitaloceanspaces.com

# ── Email ("our own sender": any SMTP endpoint, mail goes out as your domain)
# console = log only (works, but clients get no mail). smtp = real sending.
EMAIL_MODE=console
#SMTP_HOST=smtp.resend.com
#SMTP_PORT=587
#SMTP_USER=resend
#SMTP_PASS=
#EMAIL_FROM=Izsoli.lv <noreply@izsoli.lv>
