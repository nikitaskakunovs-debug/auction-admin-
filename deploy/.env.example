# Copy to deploy/.env and fill in. NEVER commit the real .env.

# ── Domains & TLS ────────────────────────────────────────────────────────────
# Your apex domain. Subdomains api.<domain> and admin.<domain> are derived.
DOMAIN=izsoli.lv
# Let's Encrypt notifications.
ACME_EMAIL=nikita.skakunovs@gmail.com
# Per-country storefront origins (only if you run the ccTLD trio; otherwise
# leave unset and everything self-references the single DOMAIN).
#ORIGIN_LV=https://izsoli.lv
#ORIGIN_EE=https://izsoli.ee
#ORIGIN_LT=https://izsoli.lt

# ── Secrets ──────────────────────────────────────────────────────────────────
# openssl rand -hex 24   (both of these)
POSTGRES_PASSWORD=
JWT_SECRET=

# ── First admin (used once by the seed; remove afterwards) ──────────────────
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
# 2FA is enforced: you enroll your authenticator on first login.

# ── Photos (DigitalOcean Spaces, FRA1) ───────────────────────────────────────
STORAGE_DRIVER=s3
S3_ENDPOINT=https://fra1.digitaloceanspaces.com
S3_REGION=fra1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# The bucket's public URL (enable CDN in Spaces and use the CDN endpoint):
S3_PUBLIC_URL=https://<bucket>.fra1.cdn.digitaloceanspaces.com

# ── Email ("our own sender": any SMTP endpoint, mail goes out as your domain)
# console = log only (works, but clients get no mail). smtp = real sending.
EMAIL_MODE=console
#SMTP_HOST=smtp.resend.com
#SMTP_PORT=587
#SMTP_USER=resend
#SMTP_PASS=
#EMAIL_FROM=Izsoli.lv <noreply@izsoli.lv>

# ── Klix payments (cards, Pay Later/BNPL, Baltic banklinks) ──────────────────
# off until the merchant agreement is signed. When Klix sends the Brand ID and
# Secret key (test keys work the same way), fill them in and set KLIX_MODE=live.
KLIX_MODE=off
#KLIX_BRAND_ID=
#KLIX_SECRET_KEY=
# Optional: pin the checkout to specific methods (comma-separated Klix ids,
# e.g. klix,klix_pay_later,swedbank_lv_pis,seb_lv_pis,luminor_lv_pis,
# citadele_lv_digilink). Leave unset to offer every method enabled on the brand.
#KLIX_METHODS=

# ── Inbank BNPL (hire purchase / installments, hosted e-POS flow) ────────────
# off until the Inbank partner agreement is signed. When Inbank sends the shop
# UUID and API key, fill them in and set INBANK_MODE=live. Partner testing
# runs against their demo environment: INBANK_API_URL=https://demo-api.inbank.eu
INBANK_MODE=off
#INBANK_API_URL=https://api.inbank.eu
#INBANK_SHOP_UUID=
#INBANK_API_KEY=
# Only needed if several financing products are configured on the shop:
#INBANK_PRODUCT_CODE=

# ── Omniva parcel shipping (OMX API) ─────────────────────────────────────────
# off until the Omniva business contract is signed. Omniva sends a customer
# code (= API username) and password; test first against their sandbox:
# OMNIVA_API_URL=https://test-omx.omniva.eu/api/v01/omx
OMNIVA_MODE=off
#OMNIVA_USERNAME=
#OMNIVA_PASSWORD=
# Sender printed on the labels (the warehouse):
#SHIP_SENDER_NAME=Skakunov's SIA
#SHIP_SENDER_PHONE=+371...
#SHIP_SENDER_EMAIL=info@izsoli.lv
#SHIP_SENDER_COUNTRY=LV
#SHIP_SENDER_POSTCODE=
#SHIP_SENDER_CITY=Rīga
#SHIP_SENDER_STREET=

# ── DPD parcel lockers ("Amber" API) ─────────────────────────────────────────
# off until the DPD business contract is signed. DPD issues an API token (or
# you generate one from your e-service credentials). Test first against the
# sandbox: DPD_API_URL=https://sandbox-eserviss.dpd.lv/api/v1
DPD_MODE=off
#DPD_API_URL=https://eserviss.dpd.lv/api/v1
#DPD_API_TOKEN=
# Locker-delivery service alias — confirm with GET /services at onboarding:
#DPD_SERVICE_ALIAS=DPD PUDO
